# NEXT_PUBLIC_API_URL: Go backend API URL including the /api/v1 prefix.
# Use a non-8080 port if another local service is already using 8080.
NEXT_PUBLIC_API_URL="http://localhost:18081/api/v1"

# Legacy fallback supported by the demo. Prefer NEXT_PUBLIC_API_URL.
# NEXT_PUBLIC_API_BASE_URL="http://localhost:18081"

# NEXT_PUBLIC_APP_URL: URL where this frontend is hosted.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

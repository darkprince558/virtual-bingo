# App settings
APP_NAME=Bingo AI Narration Service
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# AI provider mode
# Use mock for local development and tests. Use real only when Azure settings are configured.
AI_PROVIDER_MODE=mock

# Redis settings
# Used if Redis is available for sending AI messages to the game interface.
REDIS_HOST=localhost
REDIS_PORT=6379
GAME_EVENT_CHANNEL=bingo:ai-messages

# Service-to-service / browser access settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SERVICE_TO_SERVICE_TOKEN=replace-with-local-dev-token

# Text-to-speech provider
# Use mock for local testing without Azure. Use azure when AI_PROVIDER_MODE=real.
TTS_PROVIDER=mock
AUDIO_STORAGE_PROVIDER=mock

# Azure AI Speech settings
# Safe placeholders only. Do not commit real secrets.
AZURE_SPEECH_KEY=replace-with-azure-speech-key
AZURE_SPEECH_REGION=canadacentral
AZURE_SPEECH_ENDPOINT=https://canadacentral.tts.speech.microsoft.com/cognitiveservices/v1
AZURE_SPEECH_TIMEOUT_SECONDS=30

# Azure Blob Storage settings
# Safe placeholders only. Do not commit real secrets.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=replaceaccount;AccountKey=replace-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=bingo-narration-audio

# Default Azure voice
DEFAULT_VOICE_NAME=en-US-JennyNeural
